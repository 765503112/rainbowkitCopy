{
  "name": "@qinzhehan/rainbow-wallet-kit",
  "version": "0.1.6",
  "description": "A RainbowKit-style wallet connect component with MetaMask, OKX Wallet, and Phantom support.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite --config vite.demo.config.ts --host 0.0.0.0",
    "build": "npm run clean && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  }
}
